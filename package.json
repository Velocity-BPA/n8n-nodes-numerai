{
  "name": "n8n-nodes-numerai",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for Numerai AI hedge fund tournament platform providing 8 resources and 50+ operations for tournament participation, model management, stake handling, and data analysis.",
  "license": "BUSL-1.1",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-numerai.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-numerai#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-numerai/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "numerai",
    "hedge-fund",
    "ai",
    "machine-learning",
    "trading",
    "nmr",
    "cryptocurrency",
    "tournament",
    "data-science",
    "predictions",
    "staking"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/NumeraiApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Numerai/Numerai.node.js",
      "dist/nodes/Numerai/NumeraiTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && npm run copy:icons",
    "copy:icons": "cp -r nodes/Numerai/*.svg dist/nodes/Numerai/ 2>/dev/null || true",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "clean": "rm -rf dist/",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "form-data": "^4.0.0",
    "graphql": "^16.8.1",
    "graphql-request": "^6.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.4",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.22.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "n8n-workflow": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
